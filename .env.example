DATABASE_URL=postgresql+asyncpg://motoscrap:motoscrap@postgres:5432/motoscrap

# Optional. If set, /refresh requires `X-API-Key: <value>` header.
# If empty, /refresh is disabled (returns 503) to prevent unauthenticated scraping.
MOTOSCRAP_API_KEY=

HTTP_USER_AGENT=motoscrap/0.1 (+https://github.com/kemalasliyuksek/motoscrap)
HTTP_RATE_LIMIT_PER_SEC=1
HTTP_TIMEOUT_SECONDS=20

LOG_LEVEL=INFO
